# Normalize line endings: store as LF in the repo and check out as LF
# (prevents the "LF will be replaced by CRLF" warnings on Windows).
* text=auto eol=lf

# Treat binary assets as binary (never line-ending normalized).
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
